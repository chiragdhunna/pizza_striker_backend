# PostgreSQL — set all values in your .env file (no defaults in source)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=change_me
POSTGRES_PASSWORD=change_me
POSTGRES_DB=pizza_striker
# DATABASE_URL is constructed automatically from the fields above.
# You may override it explicitly if needed:
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>

# JWT — use a strong random secret in production
JWT_SECRET_KEY=change_me_to_a_strong_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_ENV=development
APP_DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
